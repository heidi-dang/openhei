{
  "$schema": "https://turborepo.com/schema.json",
  "globalEnv": ["CI", "OPENHEI_DISABLE_SHARE"],
  "globalPassThroughEnv": ["CI", "OPENHEI_DISABLE_SHARE"],
  "tasks": {
    "lint": {
      "outputs": []
    },
    "typecheck": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    }
  }
}
